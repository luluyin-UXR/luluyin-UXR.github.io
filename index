<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --mint:      #1a6b5e;
    --mint-mid:  #2a9d8f;
    --mint-light:#e6f5f2;
    --mint-pale: #f2faf8;
    --gold:      #c8890a;
    --gold-mid:  #e8a020;
    --gold-light:#fef5e4;
    --navy:      #1a3566;
    --navy-mid:  #2550a0;
    --navy-light:#edf2fb;
    --bg:        #ffffff;
    --bg2:       #f7faf9;
    --text:      #0d1f1c;
    --text-muted:#3d6b65;
    --text-dim:  #8aada8;
    --border:    rgba(26,107,94,0.12);
    --border2:   rgba(26,107,94,0.22);
    --transition:0.28s cubic-bezier(0.4,0,0.2,1);
  }

  html { scroll-behavior: smooth; font-size: 16px; }
  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', system-ui, sans-serif; font-weight: 300; line-height: 1.75; overflow-x: hidden; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.96); backdrop-filter: blur(18px); border-bottom: 1px solid var(--border); padding: 0 2.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav-logo-wrap { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
  .nav-name { font-family: 'DM Serif Display', serif; font-size: 1.05rem; color: var(--text); letter-spacing: -0.01em; line-height: 1.2; }
  .nav-name span { color: var(--mint); }
  .nav-title { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.04em; }
  .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
  .nav-links a { color: var(--text-muted); text-decoration: none; font-size: 0.84rem; font-weight: 400; transition: color var(--transition); }
  .nav-links a:hover { color: var(--mint); }
  .nav-contact { padding: 0.42rem 1rem; border-radius: 5px; background: var(--mint-light); color: var(--mint) !important; font-size: 0.75rem; font-weight: 600; border: 1.5px solid rgba(26,107,94,0.3); letter-spacing: 0.01em; }
  .nav-contact:hover { background: var(--mint) !important; color: #fff !important; }

  /* HERO */
  .hero-wrap { background: linear-gradient(155deg, #f7faf9 0%, #edf2fb 55%, #fef5e4 100%); border-bottom: 1px solid var(--border); }
  .hero { max-width: 1200px; margin: 0 auto; padding: 9rem 2.5rem 6rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .hero-tag { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--gold-light); border: 1px solid rgba(200,137,10,0.3); border-radius: 20px; padding: 0.28rem 0.85rem; font-size: 0.73rem; letter-spacing: 0.09em; text-transform: uppercase; color: var(--gold); font-weight: 600; margin-bottom: 1.5rem; }
  .hero-tag::before { content: '◆'; font-size: 0.42rem; }
  .hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.2rem, 4vw, 3.7rem); line-height: 1.12; letter-spacing: -0.03em; color: var(--text); margin-bottom: 0.3rem; }
  .hero h1 em { color: var(--mint); font-style: italic; }
  .hero-subtitle { font-size: 0.97rem; color: var(--navy); font-weight: 500; letter-spacing: 0.02em; margin-bottom: 1.1rem; }
  .hero-sub { font-size: 0.94rem; color: var(--text-muted); line-height: 1.88; max-width: 510px; margin-bottom: 2rem; }
  .hero-sub strong { color: var(--text); font-weight: 500; }
  .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn { padding: 0.68rem 1.6rem; border-radius: 6px; font-size: 0.86rem; font-weight: 500; cursor: pointer; text-decoration: none; display: inline-block; transition: all var(--transition); font-family: 'DM Sans', sans-serif; }
  .btn-navy { background: var(--navy-light); color: var(--navy); border: 1.5px solid rgba(26,53,102,0.25); }
  .btn-navy:hover { background: var(--navy); color: #fff; }
  .btn-mint { background: var(--mint); color: #fff; border: none; }
  .btn-mint:hover { background: #155c4f; }
  .btn-outline { background: transparent; color: var(--text); border: 1.5px solid var(--border2); }
  .btn-outline:hover { border-color: var(--mint); color: var(--mint); }

  /* HERO STATS */
  .hero-right { display: flex; flex-direction: column; gap: 1rem; }
  .stat-card { background: #fff; border-radius: 12px; padding: 1.2rem 1.4rem; border: 1px solid var(--border); display: flex; align-items: center; gap: 1.1rem; }
  .stat-icon { width: 42px; height: 42px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.1rem; }
  .stat-icon.mint { background: var(--mint-light); }
  .stat-icon.gold { background: var(--gold-light); }
  .stat-icon.navy { background: var(--navy-light); }
  .stat-num { font-family: 'DM Serif Display', serif; font-size: 1.75rem; color: var(--text); line-height: 1; }
  .stat-lbl { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.12rem; }

  /* FINANCE BANNER */
  .finance-banner { background: var(--gold-light); border-top: 1px solid rgba(200,137,10,0.18); border-bottom: 1px solid rgba(200,137,10,0.18); padding: 2.5rem 2.5rem; }
  .finance-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 300px 1fr; gap: 3rem; align-items: start; }
  .finance-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gold); margin-bottom: 0.35rem; font-weight: 600; }
  .finance-title { font-family: 'DM Serif Display', serif; font-size: 1.55rem; color: var(--text); line-height: 1.25; }
  .finance-title em { color: var(--mint); font-style: italic; }
  .finance-desc { font-size: 0.88rem; color: var(--text-muted); line-height: 1.85; }
  .finance-pills { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1rem; }
  .fin-pill { padding: 0.28rem 0.75rem; border-radius: 4px; font-size: 0.73rem; font-weight: 500; background: #fff; color: var(--text-muted); border: 1px solid rgba(200,137,10,0.2); }
  .fin-pill.gold { background: #fff; color: var(--gold); border-color: rgba(200,137,10,0.35); font-weight: 600; }

  /* SKILLS STRIP */
  .skills-strip { background: var(--mint-pale); border-bottom: 1px solid var(--border); padding: 1rem 0; overflow: hidden; }
  .skills-track { display: flex; gap: 2.2rem; white-space: nowrap; animation: scroll-skills 35s linear infinite; }
  .skill-tag { font-size: 0.77rem; color: var(--text-muted); letter-spacing: 0.05em; display: flex; align-items: center; gap: 0.42rem; }
  .skill-tag::before { content: '◆'; color: var(--gold-mid); font-size: 0.38rem; }
  @keyframes scroll-skills { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* SECTIONS */
  section { padding: 5rem 2.5rem; max-width: 1200px; margin: 0 auto; scroll-margin-top: 64px; }
  .section-eyebrow { font-size: 0.7rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--gold); font-weight: 600; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.55rem; }
  .section-eyebrow::before { content: ''; display: block; width: 18px; height: 2px; background: var(--gold); border-radius: 2px; }
  .section-title { font-family: 'DM Serif Display', serif; font-size: clamp(1.75rem, 3vw, 2.5rem); color: var(--text); letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 0.85rem; }
  .section-desc { font-size: 0.95rem; color: var(--text-muted); max-width: 600px; line-height: 1.88; }

  /* ABOUT */
  .about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 3.5rem; margin-top: 2.8rem; align-items: start; }
  .about-text p { color: var(--text-muted); line-height: 1.92; margin-bottom: 1.1rem; font-size: 0.93rem; }
  .about-text strong { color: var(--text); font-weight: 500; }
  .about-finance-tag { display: inline-flex; align-items: center; gap: 0.35rem; background: var(--navy-light); border: 1px solid rgba(26,53,102,0.2); border-radius: 4px; padding: 0.18rem 0.55rem; font-size: 0.72rem; color: var(--navy); font-weight: 500; margin: 0.15rem; }
  .exp-item { padding: 1rem 0; border-bottom: 1px solid var(--border); display: grid; grid-template-columns: auto 1fr; gap: 1rem; align-items: start; }
  .exp-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 0.52rem; flex-shrink: 0; }
  .exp-company { font-weight: 500; color: var(--text); font-size: 0.92rem; }
  .exp-role { font-size: 0.79rem; color: var(--mint); margin-top: 0.08rem; }
  .exp-date { font-size: 0.74rem; color: var(--text-dim); margin-top: 0.08rem; }
  .exp-sector { display: inline-block; font-size: 0.68rem; font-weight: 600; padding: 0.13rem 0.48rem; border-radius: 3px; margin-top: 0.3rem; letter-spacing: 0.04em; }
  .exp-sector.finance { background: var(--gold-light); color: var(--gold); }
  .exp-sector.marketplace { background: var(--mint-light); color: var(--mint); }
  .exp-sector.academic { background: var(--navy-light); color: var(--navy); }

  /* SECTOR BAND */
  .sector-band { background: var(--gold-light); border-top: 1px solid rgba(200,137,10,0.2); border-bottom: 1px solid rgba(200,137,10,0.2); padding: 0.9rem 2.5rem; display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }
  .sector-band-label { font-size: 0.7rem; font-weight: 700; color: var(--gold); letter-spacing: 0.09em; text-transform: uppercase; white-space: nowrap; }
  .sector-item { display: flex; align-items: center; gap: 0.38rem; font-size: 0.78rem; color: #7a5a08; }
  .sector-item::before { content: '◆'; color: var(--gold-mid); font-size: 0.38rem; }

  /* TABS */
  .cases-tabs { display: flex; gap: 0.35rem; margin-bottom: 2.5rem; flex-wrap: wrap; border-bottom: 2px solid var(--border); padding-bottom: 0; }
  .case-tab { padding: 0.58rem 1.05rem; border-radius: 6px 6px 0 0; background: transparent; color: var(--text-muted); border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; font-size: 0.81rem; font-weight: 400; transition: all var(--transition); border-bottom: 3px solid transparent; position: relative; bottom: -2px; }
  .case-tab:hover { color: var(--text); }
  .case-tab.active { color: var(--navy); border-bottom-color: var(--navy); font-weight: 500; background: var(--navy-light); }
  .case-panel { display: none; }
  .case-panel.active { display: block; animation: fadeIn 0.28s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* CARDS */
  .case-header { display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: start; margin-bottom: 2rem; }
  .case-title { font-family: 'DM Serif Display', serif; font-size: clamp(1.25rem, 2.4vw, 1.85rem); color: var(--text); letter-spacing: -0.02em; line-height: 1.3; margin-bottom: 0.4rem; }
  .case-subtitle { color: var(--text-muted); font-size: 0.88rem; }
  .case-badge { display: inline-flex; align-items: center; background: var(--navy-light); border: 1px solid rgba(26,53,102,0.2); padding: 0.38rem 0.8rem; border-radius: 20px; font-size: 0.71rem; color: var(--navy); white-space: nowrap; font-weight: 500; }
  .case-badge.gold-badge { background: var(--gold-light); border-color: rgba(200,137,10,0.25); color: var(--gold); }
  .case-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; margin-bottom: 1.3rem; }
  .case-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.1rem; margin-bottom: 1.3rem; }
  .info-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem 1.35rem; }
  .info-card h4 { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.6rem; font-weight: 600; }
  .info-card p, .info-card li { font-size: 0.87rem; color: var(--text-muted); line-height: 1.78; }
  .info-card ul { padding-left: 1rem; }
  .info-card li { margin-bottom: 0.28rem; }
  .info-card strong { color: var(--text); font-weight: 500; }
  .chart-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1.35rem; }
  .chart-card h4 { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mint); margin-bottom: 1rem; font-weight: 600; }
  .insight-block { background: #fff; border: 1px solid var(--border); border-left: 3px solid var(--mint); border-radius: 0 8px 8px 0; padding: 0.95rem 1.15rem; margin-bottom: 0.85rem; }
  .insight-block.gold-border { border-left-color: var(--gold-mid); }
  .insight-block.navy-border { border-left-color: var(--navy); }
  .insight-block h5 { font-size: 0.83rem; font-weight: 500; color: var(--text); margin-bottom: 0.22rem; }
  .insight-block p { font-size: 0.81rem; color: var(--text-muted); }
  .hmw-tag { display: inline-block; background: var(--mint-light); border: 1px solid rgba(26,107,94,0.2); border-radius: 4px; padding: 0.22rem 0.6rem; font-size: 0.73rem; color: var(--mint); margin: 0.18rem; }
  .hmw-tag.gold { background: var(--gold-light); border-color: rgba(200,137,10,0.25); color: var(--gold); }
  .hmw-tag.navy { background: var(--navy-light); border-color: rgba(26,53,102,0.2); color: var(--navy); }

  /* JOURNEY MAP */
  .journey-map { overflow-x: auto; padding-bottom: 0.5rem; }
  .journey-table { width: 100%; min-width: 680px; border-collapse: collapse; font-size: 0.8rem; }
  .journey-table th { background: var(--navy-light); color: var(--navy); font-weight: 600; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.6rem 0.8rem; border: 1px solid rgba(26,53,102,0.12); text-align: left; }
  .journey-table td { padding: 0.72rem 0.8rem; border: 1px solid var(--border); color: var(--text-muted); vertical-align: top; line-height: 1.65; }
  .journey-table .phase-cell { background: var(--navy-light); color: var(--navy); font-weight: 600; font-size: 0.83rem; white-space: nowrap; border-left: 3px solid var(--navy); }
  .pain-item { color: #9a3030; font-size: 0.77rem; margin-top: 0.18rem; }
  .pain-item::before { content: '↳ '; }
  .touchpoint-pill { display: inline-block; background: var(--mint-light); border: 1px solid rgba(26,107,94,0.2); border-radius: 4px; padding: 0.1rem 0.42rem; margin: 0.1rem; font-size: 0.71rem; color: var(--mint); }

  /* FLOW */
  .research-flow { display: flex; gap: 0; align-items: stretch; flex-wrap: wrap; margin: 0.9rem 0; }
  .flow-step { flex: 1; min-width: 108px; background: #fff; border: 1px solid var(--border); padding: 1rem 0.85rem; position: relative; text-align: center; }
  .flow-step:not(:last-child)::after { content: '→'; position: absolute; right: -13px; top: 50%; transform: translateY(-50%); color: var(--mint); font-size: 0.95rem; z-index: 1; }
  .flow-step:first-child { border-radius: 8px 0 0 8px; }
  .flow-step:last-child { border-radius: 0 8px 8px 0; }
  .flow-num { font-family: 'DM Serif Display', serif; font-size: 1.7rem; color: var(--mint); display: block; line-height: 1; }
  .flow-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.28rem; line-height: 1.4; }
  .flow-method { font-size: 0.66rem; color: var(--gold); margin-top: 0.32rem; font-weight: 600; }

  /* METHODS */
  .methods-bg { background: var(--mint-pale); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .methods-inner { max-width: 1200px; margin: 0 auto; padding: 5rem 2.5rem; }

  /* FOOTER */
  footer { background: var(--mint-light); border-top: 1px solid var(--border); color: var(--text-muted); padding: 3.5rem 2.5rem; text-align: center; font-size: 0.84rem; }
  footer a { color: var(--mint); text-decoration: none; font-weight: 500; }
  footer strong { color: var(--text); }

  /* UTILITY */
  .tags-wrap { display: flex; flex-wrap: wrap; gap: 0.33rem; margin-top: 0.65rem; }
  .method-tag { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 0.2rem 0.55rem; font-size: 0.73rem; color: var(--text-muted); }
  .mt-2 { margin-top: 2rem; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 4rem; }
    .about-grid, .case-grid, .case-grid-3 { grid-template-columns: 1fr; }
    .finance-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    nav { padding: 0 1.2rem; }
    .nav-title, .nav-contact { display: none; }
    section { padding: 4rem 1.5rem; }
    .case-header { grid-template-columns: 1fr; }
  }
</style>
</head>
